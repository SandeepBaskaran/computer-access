{
  "name": "computer-access",
  "version": "2.1.0",
  "description": "Universal Cross-Platform Local Agent MCP Server + generic coding-agent build bridge",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/start.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:bridge": "tsx tests/bridge-smoke.ts",
    "test:service": "bash tests/service-smoke.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@ngrok/ngrok": "^1.4.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "fast-glob": "^3.3.3",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.40.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.15",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.9.0": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "puppeteer@24.40.0": true
  }
}
