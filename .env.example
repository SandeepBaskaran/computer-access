# ==============================================================================
# Computer Access MCP - Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Local MCP Server Configuration ────────────────────────────────────────────
PORT=8123
NGROK_DOMAIN=your-ngrok-domain.ngrok-free.dev
NGROK_AUTHTOKEN=your-ngrok-authtoken
ALLOWED_DIRS=/Users/yourname/Documents/
COMMAND_TIMEOUT=30000
# REQUIRED for a public tunnel: the server refuses to start ngrok without this.
MCP_TOKEN=your-secret-mcp-token
CORS_ORIGINS=

# ── Session Lifecycle ─────────────────────────────────────────────────────────
# Idle timeout: session is dropped if no tool call for this many ms (default: 30 min)
SESSION_IDLE_TIMEOUT_MS=1800000
# Hard cap: a session is always dropped after this many ms regardless of activity (default: 8 hrs)
SESSION_MAX_TTL_MS=28800000

# ⚠️  DANGER: This server exposes your filesystem and terminal to the cloud.
# NEVER share your NGROK URL or MCP_TOKEN. If leaked, an attacker can control your machine.

# ── Feature Toggles (Security) ───────────────────────────────────────────────
ENABLE_WRITE_EDIT=true
ENABLE_RUN_COMMAND=true
ENABLE_GIT=true
ENABLE_FFMPEG=true
ENABLE_BROWSER=true
ENABLE_NET=true
ENABLE_DB=true
# Keychain access (secret-manage) is the largest exfiltration surface — off by default.
ENABLE_SECRETS=false

# Confirmation gate: when true, 'dangerous' actions require re-calling with confirm:true.
ENABLE_CONFIRMATION_GATE=false

# Optional least-privilege allowlist: comma-separated tool names. When set, ONLY
# these tools are registered (e.g. TOOLS=fs-manage,fs-search,git-manage).
TOOLS=

# ── Safety Limits ─────────────────────────────────────────────────────────────
# Max file read size in bytes before returning a blocked message (default: 10 MB)
MAX_READ_BYTES=10485760
# Max child-process output buffer in bytes (rg over large repos; default: 64 MB)
MAX_EXEC_BUFFER=67108864
# Rotate audit.log once it exceeds this size in bytes (default: 10 MB)
AUDIT_LOG_MAX_BYTES=10485760

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window in ms and max requests per window per IP (default: 200 req/min)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Webhook Notifications ─────────────────────────────────────────────────────
# POST a notification here after each tool call (optional)
WEBHOOK_URL=
