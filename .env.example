# ==============================================================================
# Computer Access MCP - Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Local MCP Server Configuration ────────────────────────────────────────────
PORT=8123
NGROK_DOMAIN=your-ngrok-domain.ngrok-free.dev
NGROK_AUTHTOKEN=your-ngrok-authtoken
ALLOWED_DIRS=/Users/yourname/Documents/
COMMAND_TIMEOUT=30000
MCP_TOKEN=your-secret-mcp-token
CORS_ORIGINS=

# ── Session Lifecycle ─────────────────────────────────────────────────────────
# Idle timeout: session is dropped if no tool call for this many ms (default: 30 min)
SESSION_IDLE_TIMEOUT_MS=1800000
# Hard cap: a session is always dropped after this many ms regardless of activity (default: 8 hrs)
SESSION_MAX_TTL_MS=28800000

# ⚠️  DANGER: This server exposes your filesystem and terminal to the cloud.
# NEVER share your NGROK URL or MCP_TOKEN. If leaked, an attacker can control your machine.

# ── Feature Toggles (Security) ───────────────────────────────────────────────
ENABLE_WRITE_EDIT=true
ENABLE_RUN_COMMAND=true
ENABLE_GIT=true
ENABLE_FFMPEG=true
ENABLE_BROWSER=true
ENABLE_NET=true
ENABLE_DB=true

# ── Safety Limits ─────────────────────────────────────────────────────────────
# Max file read size in bytes before returning a blocked message (default: 10 MB)
MAX_READ_BYTES=10485760

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window in ms and max requests per window per IP (default: 200 req/min)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Webhook Notifications ─────────────────────────────────────────────────────
# POST a notification here after each tool call (optional)
WEBHOOK_URL=

# ── Build Board Bridge ────────────────────────────────────────────────────────
# Coding agent used when a task doesn't name one (must be a non-stub entry in providers.json)
DEFAULT_PROVIDER=claude-code
# Task worktrees live OUTSIDE the repo tree so `git add -A` never picks them up
WORKTREE_ROOT=~/.build-board/worktrees
# Max coding-agent jobs running at once; excess dispatches return capacityExceeded
MAX_CONCURRENT_JOBS=2
# A running job with no output for this long is killed and marked failed (default: 15 min)
HEARTBEAT_TIMEOUT_MS=900000
# Hard kill for any job running longer than this (default: 2 h)
JOB_MAX_RUNTIME_MS=7200000
# Merged task branches are kept this long for `merge-task action:revert`, then cleaned up (default: 7 days)
REVERT_WINDOW_HOURS=168
# Hard runtime ceiling for read-only plan jobs, enforced by the sweep (default: 10 min).
# plan-task itself always returns immediately; this only bounds the background run.
PLAN_TIMEOUT_MS=600000
# Delay before a hold(quota) job is auto-retried by the sweep (default: 30 min).
# Only quota holds auto-retry; needs_input / session / blocked wait for a human.
HOLD_RETRY_MS=1800000
# LAST-RESORT read-only planner, used only when a provider's own plan mode
# can't be driven at all (pty spawn fails, unknown flags, no plan mode).
# The card's own agent still does the build. Set empty to disable fallback.
PLAN_FALLBACK_AGENT=claude-code
# One-shot plans shorter than this escalate to an interactive session (when the provider has one)
PLAN_MIN_CHARS=200
# An interactive plan session silent this long is inspected: trailing question →
# hold(needs_input) relayed to the board; otherwise the transcript becomes the plan
PLAN_IDLE_MS=20000

# ── Always-on service: self-scan, wake, recovery ──────────────────────────────
# Bridge's own Notion access for board self-scan (near-instant card pickup; the
# 4-hour cloud agent stays the redundant path). Use "keychain:<service>" to pull
# the token from the macOS Keychain instead of storing it here:
#   security add-generic-password -s buildboard-notion -a bridge -w <token>
NOTION_TOKEN=keychain:buildboard-notion
BOARD_DATA_SOURCE_ID=
# Board property names (defaults shown) — override if your board differs
#BOARD_PROP_STATUS=Status
#BOARD_PROP_TASK_ID=Task ID
#BOARD_PROP_REPO=Repo Path
#BOARD_PROP_AGENT=Coding Agent
#BOARD_PROP_BRIEF=Brief
#BOARD_PROP_VERIFY=Verify Command
# Self-scan interval while awake (default: 90 s; scans also fire on startup and wake)
SELF_SCAN_INTERVAL_MS=90000
# Dead-job recovery: resume (provider session, via resumeArgsTemplate) | rerun (original brief) | rework (fail with note)
RESUME_STRATEGY=resume
# Wall-clock gap treated as a wake from sleep (default: 2 min)
WAKE_GAP_MS=120000
# ngrok agent local API used to verify the tunnel service is up
TUNNEL_API_URL=http://127.0.0.1:4040/api/tunnels
# These are YOUR repos: dependency installs are user-authorized by design.
# Set false to refuse install commands on the bridge's exec surfaces.
ALLOW_PACKAGE_INSTALLS=true
# Execution posture when a card has no Mode set: auto (full autonomy) |
# accept_edits (supervised: edits auto-apply, shell/installs/deletes pause and
# the question is relayed to the board → answer-task)
DEFAULT_MODE=auto
# Board property/option names live in board-map.json (never hard-coded in logic)
# ⚠️ ENABLE_CONFIRMATION_GATE is a BREAK-GLASS switch for the bridge: when true,
# merge-task refuses outright (autonomous merges disabled; merge manually).
# The normal merge gate is the board itself — a human moving the card to Approved.
ENABLE_CONFIRMATION_GATE=false
